{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JobEntry",
  "type": "object",
  "required": [
    "id",
    "company",
    "title",
    "level",
    "region",
    "country",
    "location",
    "remote_type",
    "url",
    "source",
    "source_url",
    "posted_at",
    "collected_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9a-f]{16}$",
      "description": "16-char hex ID (stable hash of company+title+url)"
    },
    "company": {
      "type": "string",
      "minLength": 1,
      "description": "Company name"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Job title"
    },
    "level": {
      "type": "string",
      "enum": ["internship", "new_grad", "junior", "entry_level", "mid_level", "unknown"],
      "description": "Career level detected from title"
    },
    "region": {
      "type": "string",
      "enum": ["us", "canada", "emea", "remote", "unknown"],
      "description": "Geographic region"
    },
    "country": {
      "type": "string",
      "description": "Country or 'REMOTE' or 'UNKNOWN'"
    },
    "location": {
      "type": "string",
      "description": "Full location string from source"
    },
    "remote_type": {
      "type": "string",
      "enum": ["remote", "hybrid", "onsite", "unknown"],
      "description": "Work arrangement type"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "description": "Direct link to job posting"
    },
    "source": {
      "type": "string",
      "description": "Source ID (remotive, arbeitnow, etc.)"
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "description": "Source website URL for attribution"
    },
    "posted_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "Date job was posted (YYYY-MM-DD)"
    },
    "collected_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$",
      "description": "UTC timestamp when collected (ISO 8601)"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Tags (e.g., 'software', 'programming', 'global-tech-roles')"
    }
  },
  "additionalProperties": false
}
